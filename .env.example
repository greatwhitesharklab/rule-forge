# Database - App datasource
APP_DB_URL=jdbc:mysql://localhost:3306/app_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&allowPublicKeyRetrieval=true
APP_DB_USERNAME=root
APP_DB_PASSWORD=your_password_here

# Database - RuleForge datasource
RF_DB_URL=jdbc:mysql://localhost:3306/ruleforge_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&allowPublicKeyRetrieval=true
RF_DB_USERNAME=root
RF_DB_PASSWORD=your_password_here

# Service ports
CONSOLE_PORT=8081
EXECUTOR_PORT=8082

# Cross-service URLs
EXECUTOR_URL=http://localhost:8082
CONSOLE_URL=http://localhost:8081

# RuleForge repository directory
RF_REPO_DIR=./data/riskruleforge

# Lazy load
LAZY_LOAD_BASE_URL=
