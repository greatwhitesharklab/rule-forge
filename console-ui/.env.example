# RuleForge Console Docker 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ============================================
# 容器配置
# ============================================

# 前端服务暴露的端口
CONSOLE_PORT=8080

# ============================================
# 构建配置（可选）
# ============================================

# 构建版本号（用于镜像标签和VERSION.txt）
BUILD_VERSION=v1.0.0

# Git commit hash（自动获取或手动设置）
BUILD_COMMIT=abc123

# 构建时间（自动生成或手动设置）
BUILD_DATE=2026-01-02T08:00:00Z
