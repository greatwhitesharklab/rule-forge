{
  "name": "transaction",
  "label": "交易信息",
  "fields": [
    {"name": "transactionId", "label": "交易ID", "type": "string"},
    {"name": "transactionAmount", "label": "交易金额(元)", "type": "decimal"},
    {"name": "frequency1h", "label": "1小时内交易频次", "type": "integer"},
    {"name": "avgAmount7d", "label": "7日平均交易金额", "type": "decimal"},
    {"name": "merchantRiskScore", "label": "商户风险评分(0-1)", "type": "decimal"},
    {"name": "ipCountryMatch", "label": "IP国家匹配", "type": "integer", "description": "1=匹配, 0=不匹配"},
    {"name": "deviceAgeDays", "label": "设备使用天数", "type": "integer"},
    {"name": "hourOfDay", "label": "交易时段(0-23)", "type": "integer"},
    {"name": "distanceFromHome", "label": "离家距离(km)", "type": "decimal"},
    {"name": "isNewDevice", "label": "是否新设备", "type": "boolean"},
    {"name": "isNewMerchant", "label": "是否新商户", "type": "boolean"},
    {"name": "fraudProbability", "label": "欺诈概率(AI计算)", "type": "decimal", "output": true},
    {"name": "decision", "label": "决策结果", "type": "string", "output": true},
    {"name": "reason", "label": "决策原因", "type": "string", "output": true},
    {"name": "riskLevel", "label": "风险等级", "type": "string", "output": true}
  ]
}
