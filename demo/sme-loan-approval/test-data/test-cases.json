      },
      "expectedOutput": {"result": "MANUAL_REVIEW"}
    },
    {
      "id": "TC007",
      "name": "中等信用-标准产品",
      "input": {
        "applicantId": "APP007", "name": "吴芳", "age": 40, "monthlyIncome": 60000,
        "businessYears": 5, "creditHistory": "good", "debtRatio": 0.3, "loanAmount": 400000, "loanTerm": 12
      },
      "expectedOutput": {"result": "APPROVE", "creditScore": 70}
    },
    {
      "id": "TC008",
      "name": "无信用记录-人工审核",
      "input": {
        "applicantId": "APP008", "name": "郑新", "age": 26, "monthlyIncome": 35000,
        "businessYears": 2, "creditHistory": "none", "debtRatio": 0.15, "loanAmount": 200000, "loanTerm": 12
      },
      "expectedOutput": {"result": "MANUAL_REVIEW", "creditScore": 50}
    },
    {
      "id": "TC009",
