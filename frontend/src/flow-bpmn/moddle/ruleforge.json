        {
          "name": "eventBean",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ExclusiveGateway"] }
        }
      ]
    },
    {
      "name": "RuleForgeSequenceFlow",
      "extends": ["bpmn:SequenceFlow"],
      "properties": [
        {
          "name": "percent",
          "type": "Number",
          "meta": { "allowedIn": ["bpmn:SequenceFlow"] }
        },
        {
          "name": "conditionScript",
          "type": "String",
          "isAttr": false,
          "meta": { "allowedIn": ["bpmn:SequenceFlow"] }
        }
      ]
    }
