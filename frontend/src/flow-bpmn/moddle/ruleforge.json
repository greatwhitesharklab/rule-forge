{
  "name": "RuleForge",
  "prefix": "ruleforge",
  "uri": "http://ruleforge.com/schema",
  "types": [
    {
      "name": "RuleForgeTask",
      "extends": ["bpmn:ServiceTask"],
      "properties": [
        {
          "name": "file",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "project",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "version",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "taskType",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "bean",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "method",
          "type": "String",
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "script",
          "type": "String",
          "isAttr": false,
          "meta": { "allowedIn": ["bpmn:ServiceTask"] }
        },
        {
          "name": "packageId",
