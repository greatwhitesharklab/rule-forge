# RuleForge Console Docker Compose 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改配置

# =========================================
# 数据库配置
# =========================================
DB_HOST=mysql
DB_PORT=3306

# 开发环境数据库
DEV_DB_NAME=ruleforge_dev
DEV_DB_USERNAME=ruleforge_user
DEV_DB_PASSWORD=CHANGE_ME

# 生产环境数据库
PROD_DB_NAME=ruleforge_prod
PROD_DB_USERNAME=ruleforge_user
PROD_DB_PASSWORD=CHANGE_ME

# MySQL root密码
MYSQL_ROOT_PASSWORD=CHANGE_ME

# =========================================
# Redis配置
# =========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# =========================================
# 应用配置
# =========================================
# 开发环境端口
DEV_APP_PORT=8080
DEV_MANAGEMENT_PORT=8081

# 生产环境端口
PROD_APP_PORT=9090
PROD_MANAGEMENT_PORT=9091

# JVM配置
DEV_JAVA_OPTS=-Xmx1024m -Xms512m -XX:+UseG1GC
PROD_JAVA_OPTS=-Xmx2048m -Xms1024m -XX:+UseG1GC

# =========================================
# 监控配置
# =========================================
# Prometheus端口
PROMETHEUS_PORT=9090

# Grafana端口
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# =========================================
# 日志配置
# =========================================
LOG_LEVEL_DEV=DEBUG
LOG_LEVEL_PROD=INFO

# =========================================
# 构建配置
# =========================================
# Docker镜像名称
IMAGE_NAME=ruleforge-console
IMAGE_TAG=latest

# 镜像仓库（可选）
REGISTRY=

# =========================================
# 网络配置
# =========================================
# Nginx端口
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =========================================
# 安全配置
# =========================================
# 启用HTTPS
ENABLE_SSL=false

# SSL证书路径
SSL_CERT_PATH=./docker/nginx/ssl/cert.pem
SSL_KEY_PATH=./docker/nginx/ssl/key.pem
