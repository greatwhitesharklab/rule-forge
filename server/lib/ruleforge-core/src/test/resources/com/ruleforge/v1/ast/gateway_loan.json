{
  "version": "1.0",
  "id": "gateway_loan",
  "name": "网关分流审批",
  "schema": {
    "name": "LoanApplication",
    "fields": [
      { "name": "age", "type": "NUMBER", "label": "年龄" },
      { "name": "riskScore", "type": "NUMBER", "label": "风险分" },
      { "name": "decision", "type": "STRING", "label": "决策" }
    ]
  },
  "flow": {
    "id": "gateway_flow",
    "name": "Gateway Flow",
    "version": "1.0",
    "flowElements": [
      { "type": "startEvent",      "id": "start",     "name": "开始",     "implementation": "Start:start",        "position": { "x": 50,  "y": 200 } },
      { "type": "serviceTask",     "id": "t_risk",    "name": "风险评分", "implementation": "ScoreCard:risk",     "position": { "x": 220, "y": 200 } },
      { "type": "exclusiveGateway", "id": "gw",       "name": "风险网关", "defaultFlow": "f_low",                 "position": { "x": 400, "y": 200 } },
      { "type": "serviceTask",     "id": "t_approve", "name": "通过",     "implementation": "RuleSet:approve_rule", "position": { "x": 580, "y": 80 } },
      { "type": "serviceTask",     "id": "t_review",  "name": "复审",     "implementation": "RuleSet:review_rule",  "position": { "x": 580, "y": 200 } },
      { "type": "serviceTask",     "id": "t_reject",  "name": "拒绝",     "implementation": "RuleSet:reject_rule",  "position": { "x": 580, "y": 320 } },
      { "type": "endEvent",        "id": "end",       "name": "决策",     "implementation": "Decision:decision",    "position": { "x": 780, "y": 200 } },
      { "type": "sequenceFlow", "id": "f1",      "sourceRef": "start", "targetRef": "t_risk" },
      { "type": "sequenceFlow", "id": "f2",      "sourceRef": "t_risk", "targetRef": "gw" },
      { "type": "sequenceFlow", "id": "f_high",  "sourceRef": "gw", "targetRef": "t_approve", "conditionExpression": "riskScore >= 50" },
      { "type": "sequenceFlow", "id": "f_review","sourceRef": "gw", "targetRef": "t_review",  "conditionExpression": "riskScore >= 30" },
      { "type": "sequenceFlow", "id": "f_low",   "sourceRef": "gw", "targetRef": "t_reject" },
      { "type": "sequenceFlow", "id": "f5",      "sourceRef": "t_approve", "targetRef": "end" },
      { "type": "sequenceFlow", "id": "f6",      "sourceRef": "t_review",  "targetRef": "end" },
      { "type": "sequenceFlow", "id": "f7",      "sourceRef": "t_reject",  "targetRef": "end" }
    ]
  },
  "nodes": {
    "start": { "id": "start", "type": "Start", "name": "贷款申请", "schema": "LoanApplication" },
    "risk": {
      "id": "risk", "type": "ScoreCard", "name": "风险评分卡", "output": "riskScore", "aggregation": "SUM",
      "cards": [
        { "id": "age_card", "field": "age",
          "bands": [
            { "id": "b1", "condition": "age < 25", "score": 20 },
            { "id": "b2", "condition": "age >= 25 && age < 35", "score": 40 },
            { "id": "b3", "condition": "age >= 35", "score": 60 }
          ] }
      ]
    },
    "approve_rule": {
      "id": "approve_rule", "type": "RuleSet", "name": "通过规则", "hitPolicy": "FIRST_MATCH",
      "rules": [
        { "id": "r1", "condition": "riskScore >= 50",
          "actions": [ { "type": "SET_DECISION", "value": "approve" } ] }
      ]
    },
    "review_rule": {
      "id": "review_rule", "type": "RuleSet", "name": "复审规则", "hitPolicy": "FIRST_MATCH",
      "rules": [
        { "id": "r1", "condition": "riskScore >= 30",
          "actions": [ { "type": "SET_DECISION", "value": "review" } ] }
      ]
    },
    "reject_rule": {
      "id": "reject_rule", "type": "RuleSet", "name": "拒绝规则", "hitPolicy": "FIRST_MATCH",
      "rules": [
        { "id": "r1", "condition": "riskScore < 30",
          "actions": [ { "type": "SET_DECISION", "value": "reject" } ] }
      ]
    },
    "decision": {
      "id": "decision", "type": "Decision", "name": "最终决策",
      "decisionField": "decision",
      "outputs": ["approve", "review", "reject"],
      "defaultOutput": "review"
    }
  }
}
