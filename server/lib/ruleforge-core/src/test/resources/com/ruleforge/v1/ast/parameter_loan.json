{
  "version": "1.0",
  "id": "parameter_loan",
  "name": "参数库审批",
  "schema": {
    "name": "LoanApplication",
    "fields": [
      { "name": "riskScore", "type": "NUMBER", "label": "风险分" },
      { "name": "decision", "type": "STRING", "label": "决策" }
    ]
  },
  "flow": {
    "id": "parameter_flow",
    "name": "Parameter Flow",
    "version": "1.0",
    "flowElements": [
      { "type": "startEvent",  "id": "s", "name": "开始", "implementation": "Start:s" },
      { "type": "serviceTask", "id": "t", "name": "参数规则", "implementation": "RuleSet:r" },
      { "type": "endEvent",    "id": "e", "name": "决策", "implementation": "Decision:d" },
      { "type": "sequenceFlow", "id": "f1", "sourceRef": "s", "targetRef": "t" },
      { "type": "sequenceFlow", "id": "f2", "sourceRef": "t", "targetRef": "e" }
    ]
  },
  "nodes": {
    "s": { "id": "s", "type": "Start", "name": "贷款申请", "schema": "LoanApplication" },
    "r": {
      "id": "r", "type": "RuleSet", "name": "参数规则", "hitPolicy": "FIRST_MATCH",
      "rules": [
        { "id": "r1", "condition": "riskScore >= param.riskThreshold",
          "actions": [ { "type": "SET_DECISION", "value": "approve" } ] }
      ]
    },
    "d": {
      "id": "d", "type": "Decision", "name": "最终决策",
      "decisionField": "decision",
      "outputs": ["approve", "review"],
      "defaultOutput": "review"
    }
  }
}
